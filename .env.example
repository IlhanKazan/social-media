# ==========================================
# MicroBlog - Local Development Environment
# ==========================================

# --- Database ---
# Used by local docker-compose. Defaults to the postgres service.
DATABASE_URL=jdbc:postgresql://localhost:5432/social
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- Security ---
# Must be at least 32 characters long.
JWT_SECRET=dev-secret-must-be-at-least-32-bytes-long-please-change

# --- Cloudinary (Image Uploads) ---
# Required for posting images and updating avatars/covers.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email Infrastructure (Resend) - Phase 21 ---
# Set to true and provide API key to enable email sending in local dev.
# EMAIL_ENABLED=false
# RESEND_API_KEY=
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=MicroBlog

# --- AI Content Moderation (OpenAI) - Phase 25 ---
# Set to true to enable the moderation pipeline.
# MODERATION_ENABLED=false
# OPENAI_API_KEY=

# --- AI Bot Service (Gemini) - Phase 27 ---
# Set to true to enable automated bot posts.
# BOT_ENABLED=false
# GEMINI_API_KEY=

# --- Client ---
# The origin where the frontend is hosted. Used for CORS.
FRONTEND_ORIGIN=http://localhost:5173
